{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },

    "useAiSearch": {
      "value": "${USE_AI_SEARCH=false}"
    },
    "useAuthentication": {
      "value": "${USE_AUTHENTICATION=false}"
    },
    "useExistingAiFoundry": {
      "value": "${USE_EXISTING_AI_FOUNDRY=false}"
    },
    "useExistingAiSearch": {
      "value": "${USE_EXISTING_AI_SEARCH=false}"
    },

    "authTenantId": {
      "value": "${AZURE_AUTH_TENANT_ID}"
    },
    "azurePrincipalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "authClientAppId": {
      "value": "${AZURE_CLIENT_APP_ID}"
    },
    "authClientSecret": {
      "value": "${AZURE_CLIENT_APP_SECRET}"
    },

    "aiFoundryName": {
      "value": "${AI_FOUNDRY_NAME}"
    },
    "aiFoundryEndpoint": {
      "value": "${AI_FOUNDRY_ENDPOINT}"
    },
    "aiFoundryApiVersion": {
      "value": "${AI_FOUNDRY_API_VERSION}"
    },
    "azureOpenAiApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION}"
    },

    "azureAiSearchName": {
      "value": "${AZURE_AI_SEARCH_NAME}"
    },
    "azureAiSearchResourceGroupName": {
      "value": "${AZURE_AI_SEARCH_RESOURCE_GROUP_NAME}"
    },
    "azureAiSearchLocation": {
      "value": "${AZURE_AI_SEARCH_LOCATION}"
    },
    "aiSearchSkuName": {
      "value": "${AI_SEARCH_SKU_NAME=basic}"
    }
  }
}
